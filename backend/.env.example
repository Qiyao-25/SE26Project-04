PAPERMATE_ENV=dev
PAPERMATE_VERSION=0.1.0
PAPERMATE_DATABASE_URL=sqlite:///./data/dev.db
PAPERMATE_ECHO_SQL=false

PAPERMATE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# DeepSeek Summarize Agent（勿把真实 key 提交到 git）
PAPERMATE_DEEPSEEK_API_KEY=
PAPERMATE_DEEPSEEK_API_BASE=https://api.deepseek.com
PAPERMATE_DEEPSEEK_MODEL=deepseek-v4-flash
PAPERMATE_PARSE_AGENT_ENABLED=true
PAPERMATE_PARSE_AGENT_MAX_PAGES=12
PAPERMATE_PARSE_AGENT_TIMEOUT_S=90
