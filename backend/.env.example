PAPERMATE_ENV=dev
PAPERMATE_VERSION=0.1.0
PAPERMATE_DATABASE_URL=sqlite:///./data/dev.db
PAPERMATE_ECHO_SQL=false
PAPERMATE_AUTH_SECRET=replace-with-a-long-random-secret

PAPERMATE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5177,http://127.0.0.1:5177

# This file is a template only. Copy it to backend/.env for local runtime use.
# Values exported in the shell take precedence over values in backend/.env.
# Canonical LLM configuration. AGENT_* names remain supported for compatibility.
PAPERMATE_LLM_API_KEY=replace-with-your-api-key
PAPERMATE_LLM_MODEL=deepseek-v4-flash
PAPERMATE_LLM_API_BASE=https://api.deepseek.com
PAPERMATE_PARSE_AGENT_ENABLED=true
PAPERMATE_QA_AGENT_ENABLED=true
PAPERMATE_SEARCH_AGENT_ENABLED=true
PAPERMATE_GRAPH_AGENT_ENABLED=true
PAPERMATE_ASSIST_AGENT_ENABLED=true
PAPERMATE_WORKER_TOKEN=replace-with-local-worker-token
PAPERMATE_SEARCH_AGENT_TIMEOUT_S=45
# 生产建议 false；开发/验收可 true
PAPERMATE_ENABLE_DOCS=true
PAPERMATE_CRAWL_ENABLED=true
PAPERMATE_CRAWL_INTERVAL_S=21600
# DEBUG: 手动全站抓取 API；正式上线后改为 false，并删除 app/api/debug_crawl.py
PAPERMATE_ENABLE_CRAWL_DEBUG=true

# Legacy equivalent names, if needed:
# PAPERMATE_AGENT_ENABLED=true
# PAPERMATE_AGENT_API_KEY=replace-with-your-api-key
# PAPERMATE_AGENT_MODEL=deepseek-v4-flash
# PAPERMATE_AGENT_BASE_URL=https://api.deepseek.com
