# 前端生产构建环境变量
# 构建前复制为 UIPrototype/frontend/.env.production

# 必须关闭 Mock
VITE_USE_MOCK=false

# 与 Nginx 同源反代配合：浏览器请求 /api → Nginx → FastAPI
VITE_API_BASE_URL=/api

# 生产构建不使用 Vite 开发代理；保留仅作说明
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# 解析/问答可能较慢
VITE_API_TIMEOUT_MS=90000

# DEBUG: 设置页「全站订阅抓取」按钮；正式构建改为 false
VITE_ENABLE_CRAWL_DEBUG=true
