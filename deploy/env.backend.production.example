# PaperMate 生产环境配置模板
# 复制为 backend/.env 后填写真实值；切勿提交含密钥的 .env

PAPERMATE_ENV=prod
PAPERMATE_VERSION=0.1.0

# 正式交付推荐 PostgreSQL；小规模演示可用 sqlite:///./data/prod.db
PAPERMATE_DATABASE_URL=postgresql+psycopg://papermate:CHANGE_ME@127.0.0.1:5432/papermate
PAPERMATE_ECHO_SQL=false

# 必须替换为足够长的随机串
PAPERMATE_AUTH_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# 浏览器实际访问来源（含协议与端口）；同源反代时可写公网域名
PAPERMATE_CORS_ORIGINS=https://papermate.example.com

# 生产默认关闭 Swagger；验收需要时可临时设为 true
PAPERMATE_ENABLE_DOCS=false

PAPERMATE_LLM_API_KEY=CHANGE_ME
PAPERMATE_LLM_MODEL=deepseek-v4-flash
PAPERMATE_LLM_API_BASE=https://api.deepseek.com
PAPERMATE_PARSE_AGENT_ENABLED=true
PAPERMATE_QA_AGENT_ENABLED=true
PAPERMATE_SEARCH_AGENT_ENABLED=true
PAPERMATE_GRAPH_AGENT_ENABLED=true
PAPERMATE_ASSIST_AGENT_ENABLED=true

# 若启用独立 PaperPipeline Worker，必须与 Worker 端一致
PAPERMATE_WORKER_TOKEN=CHANGE_ME_WORKER_TOKEN

PAPERMATE_CRAWL_ENABLED=true
PAPERMATE_CRAWL_INTERVAL_S=21600
PAPERMATE_SEARCH_AGENT_TIMEOUT_S=45
PAPERMATE_PARSE_AGENT_TIMEOUT_S=90
PAPERMATE_QA_AGENT_TIMEOUT_S=90
